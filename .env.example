# ─────────────────────────────────────────────────────────────
# Workflow Toolkit — Required Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────

# Jira (Atlassian Cloud)
JIRA_BASE_URL=https://<YOUR_ATLASSIAN>.atlassian.net
JIRA_EMAIL=<YOUR_EMAIL>
JIRA_API_TOKEN=<atlassian-api-token>
JIRA_PROJECT_KEY=<PROJECT>

# Confluence (same instance as Jira)
CONFLUENCE_BASE_URL=https://<YOUR_ATLASSIAN>.atlassian.net/wiki
CONFLUENCE_EMAIL=<YOUR_EMAIL>
CONFLUENCE_API_TOKEN=<atlassian-api-token>
CONFLUENCE_SPACE_KEY=<SPACE>

# ServiceDesk Plus (Zoho)
# JSON blob with client_id, client_secret, refresh_token from the SDP OAuth app
WWEEKS_SDP={"client_id":"...","client_secret":"...","refresh_token":"..."}
SDP_BASE_URL=https://<YOUR_SDP>.sdpondemand.manageengine.com

# Azure (optional — most scripts use `az` CLI auth)
AZURE_TENANT_ID=<AZURE_TENANT_ID>
AZURE_SUBSCRIPTION_ID=<AZURE_SUBSCRIPTION_ID>

# GitHub
GITHUB_TOKEN=<github-pat>
GITHUB_ORG=<GITHUB_ORG>

# Microsoft Teams (optional — for end-of-day standup posts)
TEAMS_WEBHOOK_URL=https://<your-tenant>.webhook.office.com/...
