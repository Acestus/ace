# ─────────────────────────────────────────────────────────────
# Workflow Toolkit — Required Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────

# Linear
LINEAR_API_KEY=<linear-personal-api-key>
LINEAR_TEAM_KEY=<TEAM>              # e.g. ENG
# Optional: override Linear workflow state names (defaults shown)
# LINEAR_STATE_QUEUE=Backlog
# LINEAR_STATE_ACTIVE=In Progress
# LINEAR_STATE_WAITING=In Review
# LINEAR_STATE_DONE=Done

# Notion
NOTION_API_KEY=<notion-integration-token>
NOTION_ROOT_PAGE_ID=<default-parent-page-id>   # page ID for new articles

# Azure (optional — most scripts use `az` CLI auth)
AZURE_TENANT_ID=<AZURE_TENANT_ID>
AZURE_SUBSCRIPTION_ID=<AZURE_SUBSCRIPTION_ID>

# GitHub
GITHUB_TOKEN=<github-pat>
GITHUB_ORG=<GITHUB_ORG>

# Microsoft Teams (optional — for end-of-day standup posts)
TEAMS_WEBHOOK_URL=https://<your-tenant>.webhook.office.com/...
